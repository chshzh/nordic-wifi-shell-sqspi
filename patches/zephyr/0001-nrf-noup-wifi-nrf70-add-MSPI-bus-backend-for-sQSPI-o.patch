diff --git a/boards/shields/nrf7002eb2_mspi/Kconfig.shield b/boards/shields/nrf7002eb2_mspi/Kconfig.shield
new file mode 100644
index 00000000000..96910acfe05
--- /dev/null
+++ b/boards/shields/nrf7002eb2_mspi/Kconfig.shield
@@ -0,0 +1,11 @@
+# Copyright (c) 2026 Nordic Semiconductor ASA
+# SPDX-License-Identifier: Apache-2.0
+
+config SHIELD_NRF7002EB2_MSPI
+	bool "nRF7002 EB-II (MSPI/sQSPI, QSPI HW modification required)"
+	help
+	  Enable the nRF7002 EB-II Wi-Fi shield using the sQSPI soft peripheral
+	  via the Zephyr MSPI API (nordic,nrf-sqspi driver).
+	  Requires hardware modification on the EB-II board (SB1-SB4 cut,
+	  SB5-SB8 soldered) to route QSPI data lines to the expansion header.
+	  Supported board: nRF54LM20DK.
diff --git a/boards/shields/nrf7002eb2_mspi/boards/nrf54lm20dk_nrf54lm20a_cpuapp.overlay b/boards/shields/nrf7002eb2_mspi/boards/nrf54lm20dk_nrf54lm20a_cpuapp.overlay
new file mode 100644
index 00000000000..adf961d6619
--- /dev/null
+++ b/boards/shields/nrf7002eb2_mspi/boards/nrf54lm20dk_nrf54lm20a_cpuapp.overlay
@@ -0,0 +1,78 @@
+/*
+ * Copyright (c) 2026 Nordic Semiconductor ASA
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ *
+ * Board overlay for nRF54LM20DK + nRF7002 EB-II with QSPI HW modification.
+ *
+ * This overlay:
+ *   1. Reduces cpuapp_sram to 496 KB to leave 16 KB at 0x2007c000 for sQSPI.
+ *   2. Configures cpuflpr_vpr pinctrl and IRQ for the sQSPI soft peripheral.
+ *
+ * Console: UART20 (VCOM1, P1.16/P1.17) — the nRF54LM20DK default. No redirect needed;
+ * UART20 pins are not used by the nRF7002 EB-II expansion header.
+ *
+ * sQSPI pin mapping (Port 2, SDP pins via solder bridges SB5-SB8):
+ *   P2.0 = DQ3 (expansion header pin 16)
+ *   P2.1 = SCK (expansion header pin 17)
+ *   P2.2 = DQ0 (expansion header pin 18)
+ *   P2.3 = DQ2 (expansion header pin 19) <- requires SB7 modification
+ *   P2.4 = DQ1 (expansion header pin 20)
+ *   P2.5 = CS0 (expansion header pin 21) <- requires SB5/SB8 modifications
+ */
+
+/* Reduce app-core SRAM by 16 KB so the softperipheral_ram at 0x2007c000 does
+ * not overlap with linker-allocated sections.
+ */
+&cpuapp_sram {
+	reg = <0x20000000 DT_SIZE_K(496)>;
+	ranges = <0x0 0x20000000 DT_SIZE_K(496)>;
+};
+
+/* sQSPI pinctrl on Port 2 (SDP MSPI functions) */
+&pinctrl {
+	/omit-if-no-ref/ sqspi_default: sqspi_default {
+		group1 {
+			psels = <NRF_PSEL(SDP_MSPI_SCK, 2, 1)>,
+				<NRF_PSEL(SDP_MSPI_CS0, 2, 5)>,
+				<NRF_PSEL(SDP_MSPI_DQ0, 2, 2)>;
+			nordic,drive-mode = <NRF_DRIVE_E0E1>;
+		};
+		group2 {
+			psels = <NRF_PSEL(SDP_MSPI_DQ1, 2, 4)>,
+				<NRF_PSEL(SDP_MSPI_DQ2, 2, 3)>,
+				<NRF_PSEL(SDP_MSPI_DQ3, 2, 0)>;
+			nordic,drive-mode = <NRF_DRIVE_E0E1>;
+			bias-pull-up;
+		};
+	};
+
+	/omit-if-no-ref/ sqspi_sleep: sqspi_sleep {
+		group1 {
+			low-power-enable;
+			psels = <NRF_PSEL(SDP_MSPI_SCK, 2, 1)>,
+				<NRF_PSEL(SDP_MSPI_CS0, 2, 5)>,
+				<NRF_PSEL(SDP_MSPI_DQ0, 2, 2)>,
+				<NRF_PSEL(SDP_MSPI_DQ1, 2, 4)>,
+				<NRF_PSEL(SDP_MSPI_DQ2, 2, 3)>,
+				<NRF_PSEL(SDP_MSPI_DQ3, 2, 0)>;
+		};
+	};
+
+};
+
+/*
+ * Enable the FLPR VPR co-processor for sQSPI.
+ * - pinctrl: SDP MSPI pins on Port 2
+ * - interrupts: IRQ 76 = FLPR -> AppCore "transfer done" signal
+ * - NO execution-memory/source-memory: sQSPI driver loads its own firmware
+ */
+&cpuflpr_vpr {
+	pinctrl-0 = <&sqspi_default>;
+	pinctrl-1 = <&sqspi_sleep>;
+	pinctrl-names = "default", "sleep";
+	interrupts = <76 NRF_DEFAULT_IRQ_PRIORITY>;
+	status = "okay";
+};
+
+/* Console: UART20 (VCOM1, P1.16/P1.17) is the nRF54LM20DK default — no redirect needed. */
diff --git a/boards/shields/nrf7002eb2_mspi/nrf7002eb2_mspi.overlay b/boards/shields/nrf7002eb2_mspi/nrf7002eb2_mspi.overlay
new file mode 100644
index 00000000000..c4095cf6b19
--- /dev/null
+++ b/boards/shields/nrf7002eb2_mspi/nrf7002eb2_mspi.overlay
@@ -0,0 +1,94 @@
+/*
+ * Copyright (c) 2026 Nordic Semiconductor ASA
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ *
+ * nRF7002 EB-II shield using the sQSPI (MSPI API) bus.
+ *
+ * Requires hardware modification on the EB-II board:
+ *   Cut SB1-SB4, solder SB5-SB8 to route QSPI signals to the expansion header.
+ * See: https://docs.nordicsemi.com/bundle/ug_nrf7002_eb2/page/UG/nrf7002_EK/hw_wifi_strap_qspi.html
+ *
+ * Supported on nRF54LM20DK only. The softperipheral RAM is placed at 0x2007c000
+ * (top 16 KB carved from cpuapp SRAM — see boards overlay).
+ */
+
+/ {
+	chosen {
+		zephyr,wifi = &wlan0;
+	};
+};
+
+/ {
+	reserved-memory {
+		#address-cells = <1>;
+		#size-cells = <1>;
+		ranges;
+
+		/*
+		 * 16 KB block for the sQSPI soft peripheral firmware and registers.
+		 * The QSPI2 register file lives at offset 0x3b40 within this block.
+		 * cpuapp_sram must be reduced by 16 KB to avoid overlap (see board overlay).
+		 */
+		softperipheral_ram: memory@2007c000 {
+			reg = <0x2007c000 0x4000>;
+			ranges = <0x0 0x2007c000 0x4000>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			sqspi: sqspi@3b40 {
+				compatible = "nordic,nrf-sqspi";
+				#address-cells = <1>;
+				#size-cells = <0>;
+				reg = <0x3b40 0x200>;
+				status = "okay";
+				zephyr,pm-device-runtime-auto;
+
+				nrf70: nrf7002-mspi@0 {
+					compatible = "nordic,nrf7002-mspi";
+					reg = <0>;
+					status = "okay";
+
+					/* Bus configuration: 32 MHz quad 1-4-4 */
+					mspi-max-frequency = <DT_FREQ_M(32)>;
+					mspi-io-mode = "MSPI_IO_MODE_QUAD_1_4_4";
+					mspi-data-rate = "MSPI_DATA_RATE_SINGLE";
+					mspi-hardware-ce-num = <0>;
+					mspi-cpp-mode = "MSPI_CPP_MODE_0";
+					mspi-endian = "MSPI_BIG_ENDIAN";
+					mspi-ce-polarity = "MSPI_CE_ACTIVE_LOW";
+
+					/* 2.4 GHz TX power limits */
+					wifi-max-tx-pwr-2g-dsss = <21>;
+					wifi-max-tx-pwr-2g-mcs0 = <16>;
+					wifi-max-tx-pwr-2g-mcs7 = <16>;
+
+					/* 5 GHz TX power limits */
+					wifi-max-tx-pwr-5g-low-mcs0 = <13>;
+					wifi-max-tx-pwr-5g-low-mcs7 = <13>;
+					wifi-max-tx-pwr-5g-mid-mcs0 = <13>;
+					wifi-max-tx-pwr-5g-mid-mcs7 = <13>;
+					wifi-max-tx-pwr-5g-high-mcs0 = <12>;
+					wifi-max-tx-pwr-5g-high-mcs7 = <12>;
+
+					wlan0: wlan0 {
+						compatible = "nordic,wlan";
+					};
+				};
+			};
+		};
+	};
+};
+
+/*
+ * Power control and interrupt GPIOs.
+ * These are on Port 1 (not affected by sQSPI Port 2 SDP pins).
+ *   pin 4 -> gpio1.4  (BUCKEN)
+ *   pin 5 -> gpio1.13 (IOVDD_CTRL)
+ *   pin 14 -> gpio1.5 (HOST_IRQ)
+ */
+&nrf70 {
+	iovdd-ctrl-gpios = <&nordic_expansion_header 5 GPIO_ACTIVE_HIGH>;
+	bucken-gpios     = <&nordic_expansion_header 4 GPIO_ACTIVE_HIGH>;
+	host-irq-gpios   = <&nordic_expansion_header 14 GPIO_ACTIVE_HIGH>;
+};
