diff --git a/modules/nrf_wifi/bus/mspi_if.c b/modules/nrf_wifi/bus/mspi_if.c
new file mode 100644
index 00000000000..20a0da2668d
--- /dev/null
+++ b/modules/nrf_wifi/bus/mspi_if.c
@@ -0,0 +1,336 @@
+/*
+ * Copyright (c) 2024 Nordic Semiconductor ASA
+ * Copyright (c) 2026 Embeint Inc
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+/**
+ * @brief File containing MSPI device interface specific definitions for the
+ * Zephyr OS layer of the Wi-Fi driver.
+ *
+ * Uses the standard Zephyr MSPI API backed by the nordic,nrf-sqspi driver
+ * (mspi_sqspi.c). The nRF7002 is connected via sQSPI running on the FLPR
+ * VPR co-processor on nRF54L/nRF54LM series SoCs.
+ */
+
+#include <errno.h>
+#include <string.h>
+
+#include <zephyr/drivers/mspi.h>
+#include <zephyr/drivers/wifi/nrf_wifi/bus/qspi_if.h>
+#include <zephyr/logging/log.h>
+#include <zephyr/pm/device_runtime.h>
+
+#include "mspi_if.h"
+
+#define NRF7002_NODE DT_NODELABEL(nrf70)
+
+BUILD_ASSERT(DT_ENUM_IDX(NRF7002_NODE, mspi_io_mode) == MSPI_IO_MODE_QUAD_1_4_4,
+	     "Only quad 1-4-4 IO mode supported for nRF7002 MSPI");
+
+static const struct device *bus = DEVICE_DT_GET(DT_BUS(NRF7002_NODE));
+static const struct mspi_dev_id mspi_id = MSPI_DEVICE_ID_DT(NRF7002_NODE);
+static const struct mspi_dev_cfg mspi_cfg = MSPI_DEVICE_CONFIG_DT(NRF7002_NODE);
+static struct qspi_config *config;
+
+LOG_MODULE_DECLARE(wifi_nrf_bus, CONFIG_WIFI_NRF70_BUSLIB_LOG_LEVEL);
+
+static int mspi_config_apply(enum mspi_io_mode io_mode, uint32_t frequency)
+{
+	const struct mspi_dev_cfg cfg = {
+		.io_mode = io_mode,
+		.freq    = frequency,
+	};
+	const enum mspi_dev_cfg_mask mask =
+		MSPI_DEVICE_CONFIG_IO_MODE | MSPI_DEVICE_CONFIG_FREQUENCY;
+	int rc;
+
+	rc = mspi_dev_config(bus, &mspi_id, mask, &cfg);
+	if (rc < 0) {
+		LOG_ERR("dev_config() failed: %d", rc);
+	}
+	return rc;
+}
+
+static int mspi_xfer_tx(unsigned int addr, void *data, unsigned int len)
+{
+	struct mspi_xfer_packet packet = {
+		.dir      = MSPI_TX,
+		.cmd      = 0x38, /* PP4IO opcode — quad write */
+		.address  = addr,
+		.num_bytes = len,
+		.data_buf = data,
+	};
+	struct mspi_xfer xfer = {
+		.xfer_mode  = MSPI_PIO,
+		.tx_dummy   = 0,
+		.cmd_length  = 1,
+		.addr_length = 3,
+		.packets    = &packet,
+		.num_packet = 1,
+		.timeout    = 1000,
+	};
+	int rc;
+
+	/* Switch to quad mode at full frequency for bulk write */
+	rc = mspi_config_apply(mspi_cfg.io_mode, mspi_cfg.freq);
+	if (rc < 0) {
+		return rc;
+	}
+	rc = mspi_transceive(bus, &mspi_id, &xfer);
+	if (rc < 0) {
+		LOG_ERR("transceive() TX failed: %d", rc);
+	}
+	return rc;
+}
+
+static int mspi_xfer_rx(unsigned int addr, void *data, unsigned int len,
+			bool extra_rx_latency)
+{
+	struct mspi_xfer_packet packet = {
+		.dir      = MSPI_RX,
+		.cmd      = 0xEB, /* READ4IO opcode — quad read */
+		/* Address shifted left 8 bits: 3B address + 1B mode byte in addr field */
+		.address  = addr << 8,
+		.num_bytes = len,
+		.data_buf = data,
+	};
+	struct mspi_xfer xfer = {
+		.xfer_mode  = MSPI_PIO,
+		.tx_dummy   = 0,
+		.rx_dummy   = 8,   /* base dummy cycles */
+		.cmd_length  = 1,
+		.addr_length = 4,  /* 3B addr + 1B mode = 4 bytes */
+		.packets    = &packet,
+		.num_packet = 1,
+		.timeout    = 1000,
+	};
+	int rc;
+
+	/* High-latency blocks need extra dummy cycles (matches qspi_if.c behavior) */
+	if (extra_rx_latency) {
+		xfer.rx_dummy += 8;
+	}
+
+	LOG_DBG("RX addr=0x%06x len=%d extra_lat=%d rx_dummy=%d",
+		addr, len, extra_rx_latency, xfer.rx_dummy);
+
+	/* Switch to quad mode at full frequency for bulk read */
+	rc = mspi_config_apply(mspi_cfg.io_mode, mspi_cfg.freq);
+	if (rc < 0) {
+		return rc;
+	}
+	rc = mspi_transceive(bus, &mspi_id, &xfer);
+	if (rc < 0) {
+		LOG_ERR("transceive() RX failed: %d", rc);
+	} else {
+		LOG_DBG("RX result 0x%06x -> 0x%08x (rc=%d)",
+			addr, len >= 4 ? *(uint32_t *)data : 0, rc);
+	}
+	return rc;
+}
+
+/**
+ * @brief Single-lane register read/write for RPU wakeup / status registers.
+ *
+ * The nRF7002 RPU wakeup sequence uses single-mode SPI at registers 0x1F, 0x2F, 0x3F.
+ * A configurable frequency allows wakeup at 8 MHz (reliable) and status reads at full
+ * speed.
+ */
+static int mspi_reg_write(uint8_t reg, uint8_t val, uint32_t frequency)
+{
+	struct mspi_xfer_packet packet = {
+		.dir      = MSPI_TX,
+		.cmd      = reg,
+		.num_bytes = sizeof(val),
+		.data_buf = &val,
+	};
+	struct mspi_xfer xfer = {
+		.xfer_mode  = MSPI_PIO,
+		.cmd_length  = 1,
+		.addr_length = 0,
+		.packets    = &packet,
+		.num_packet = 1,
+		.timeout    = 1000,
+	};
+	int rc;
+
+	/* Single-lane at requested frequency */
+	rc = mspi_config_apply(MSPI_IO_MODE_SINGLE, frequency);
+	if (rc < 0) {
+		return rc;
+	}
+	rc = mspi_transceive(bus, &mspi_id, &xfer);
+	if (rc < 0) {
+		LOG_ERR("transceive() reg_write(0x%02x) failed: %d", reg, rc);
+	}
+	return rc;
+}
+
+static int mspi_reg_read(uint8_t reg, uint8_t *val)
+{
+	struct mspi_xfer_packet packet = {
+		.dir      = MSPI_RX,
+		.cmd      = reg,
+		.num_bytes = sizeof(*val),
+		.data_buf = val,
+	};
+	struct mspi_xfer xfer = {
+		.xfer_mode  = MSPI_PIO,
+		.cmd_length  = 1,
+		.addr_length = 0,
+		.packets    = &packet,
+		.num_packet = 1,
+		.timeout    = 1000,
+	};
+	int rc;
+
+	/* Single-lane at full frequency for status reads */
+	rc = mspi_config_apply(MSPI_IO_MODE_SINGLE, mspi_cfg.freq);
+	if (rc < 0) {
+		return rc;
+	}
+	rc = mspi_transceive(bus, &mspi_id, &xfer);
+	if (rc < 0) {
+		LOG_ERR("transceive() reg_read(0x%02x) failed: %d", reg, rc);
+	}
+	return rc;
+}
+
+int mspi_init(struct qspi_config *config_ptr)
+{
+	int rc;
+
+	config = config_ptr;
+	k_sem_init(&config->lock, 1, 1);
+
+	if (!device_is_ready(bus)) {
+		LOG_ERR("MSPI bus %s is not ready", bus->name);
+		return -ENODEV;
+	}
+
+	rc = pm_device_runtime_get(bus);
+	if (rc < 0) {
+		LOG_ERR("pm_device_runtime_get() failed: %d", rc);
+		return rc;
+	}
+
+	/* Apply full device configuration (io_mode, freq, endian, CE polarity, etc.) */
+	rc = mspi_dev_config(bus, &mspi_id, MSPI_DEVICE_CONFIG_ALL, &mspi_cfg);
+	return rc;
+}
+
+int mspi_deinit(void)
+{
+	return pm_device_runtime_put(bus);
+}
+
+int mspi_write(unsigned int addr, const void *data, int len)
+{
+	int status;
+
+	addr |= config->addrmask;
+	k_sem_take(&config->lock, K_FOREVER);
+	status = mspi_xfer_tx(addr, (void *)data, len);
+	k_sem_give(&config->lock);
+	return status;
+}
+
+int mspi_read(unsigned int addr, void *data, int len)
+{
+	int status;
+
+	addr |= config->addrmask;
+	k_sem_take(&config->lock, K_FOREVER);
+	status = mspi_xfer_rx(addr, data, len, false);
+	k_sem_give(&config->lock);
+	return status;
+}
+
+static int mspi_hl_readw(unsigned int addr, void *data)
+{
+	int status;
+
+	k_sem_take(&config->lock, K_FOREVER);
+	/* Extra latency for frequencies >= 16 MHz (matches qspi_if / spi_if behavior) */
+	status = mspi_xfer_rx(addr, data, 4, mspi_cfg.freq >= MHZ(16));
+	k_sem_give(&config->lock);
+	return status;
+}
+
+int mspi_hl_read(unsigned int addr, void *data, int len)
+{
+	int count = 0;
+	int status;
+
+	while (count < (len / 4)) {
+		status = mspi_hl_readw(addr + (4 * count), (char *)data + (4 * count));
+		if (status < 0) {
+			return status;
+		}
+		count++;
+	}
+	return 0;
+}
+
+int mspi_cmd_sleep_rpu_fn(void)
+{
+	return mspi_reg_write(0x3F, 0x00, mspi_cfg.freq);
+}
+
+int mspi_validate_rpu_wake_writecmd(void)
+{
+	int ret;
+	uint8_t val = 0;
+
+	for (int ii = 0; ii < 10; ii++) {
+		ret = mspi_reg_read(0x2F, &val);
+		if (!ret && (val & RPU_WAKEUP_NOW)) {
+			break;
+		}
+		k_msleep(1);
+	}
+
+	if (ret || !(val & RPU_WAKEUP_NOW)) {
+		LOG_ERR("RPU wakeup write ACK failed even after 10ms (val=0x%02x ret=%d)", val, ret);
+		return -1;
+	}
+	return ret;
+}
+
+int mspi_cmd_rpu_wakeup_fn(uint8_t data)
+{
+	/* Wakeup is only reliable at 8 MHz (matches spi_if.c behavior) */
+	return mspi_reg_write(0x3F, data, MHZ(8));
+}
+
+int mspi_wait_while_rpu_awake(void)
+{
+	int ret;
+	uint8_t val = 0;
+
+	for (int ii = 0; ii < 10; ii++) {
+		ret = mspi_reg_read(0x1F, &val);
+		if (!ret && (val & RPU_AWAKE_BIT)) {
+			break;
+		}
+		k_msleep(1);
+	}
+
+	if (ret || !(val & RPU_AWAKE_BIT)) {
+		LOG_ERR("RPU is not awake even after 10ms (val=0x%02x ret=%d)", val, ret);
+		return -1;
+	}
+	return val;
+}
+
+int mspi_write_reg(uint8_t reg_addr, const uint8_t reg_value)
+{
+	return mspi_reg_write(reg_addr, reg_value, mspi_cfg.freq);
+}
+
+int mspi_read_reg(uint8_t reg_addr, uint8_t *reg_value)
+{
+	return mspi_reg_read(reg_addr, reg_value);
+}
